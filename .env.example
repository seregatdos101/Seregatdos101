# ============================================
# 🔥 AVITO BOT PRO v2026 - КОНФИГУРАЦИЯ
# ============================================
# Скопируй этот файл как .env и заполни своими данными:
#   cp .env.example .env

# ============================================
# 📱 АККАУНТЫ АВИТО (до 5 штук)
# Формат: phone:password
# ============================================
ACCOUNT_1=+79001234567:MyPassword123
ACCOUNT_2=+79001234568:MyPassword456
ACCOUNT_3=
ACCOUNT_4=
ACCOUNT_5=

# ============================================
# 🌐 ПРОКСИ (HTTP или SOCKS5, с авторизацией)
# Форматы:
#   http://user:pass@ip:port
#   socks5://user:pass@ip:port
#
# Если прокси одна на все аккаунты — заполни
# только PROXY_1, оста��ьные оставь пустыми.
# Система автоматически будет ротировать.
# ============================================
PROXY_1=http://user1:pass1@1.2.3.4:8080
PROXY_2=http://user2:pass2@5.6.7.8:8080
PROXY_3=
PROXY_4=
PROXY_5=

# ============================================
# 🤖 TELEGRAM УВЕДОМЛЕНИЯ
# ============================================
TELEGRAM_BOT_TOKEN=8490914170:AAE0nRokcJutzL7HVBM5zqjYbrzuKf89LAY
TELEGRAM_CHAT_ID=-1002345678901

# Что отправлять в Telegram:
TG_NOTIFY_LOGIN=true
TG_NOTIFY_WARMUP=true
TG_NOTIFY_BAN=true
TG_NOTIFY_CAPTCHA=true
TG_NOTIFY_PROXY_DOWN=true
TG_NOTIFY_ERRORS=true

# ============================================
# 🔥 НАСТРОЙКИ ПРОГРЕВА
# ============================================
# Длительность прогрева в минутах (рекомендуется 120)
WARMUP_DURATION_MINUTES=120

# Категории для прогрева (через запятую)
WARMUP_CATEGORIES=мототехника,питбайки,квадроциклы,мотоциклы

# ============================================
# 🛡️ БЕЗОПАСНОСТЬ
# ============================================
# Максимум действий в час на аккаунт
MAX_ACTIONS_PER_HOUR=15

# Максимум действий в день на аккаунт
MAX_ACTIONS_PER_DAY=100

# Ночной режим (бот спит)
NIGHT_MODE_START=23:00
NIGHT_MODE_END=07:00

# Circuit Breaker: после скольких ошибок подряд остановить аккаунт
CIRCUIT_BREAKER_THRESHOLD=5

# Circuit Breaker: на сколько минут остановить
CIRCUIT_BREAKER_COOLDOWN_MINUTES=30

# ============================================
# 🌐 БРАУЗЕР
# ============================================
# true = без окна (для сервера), false = с окном (для отладки)
HEADLESS=false

# Таймаут загрузки страницы (секунды)
PAGE_LOAD_TIMEOUT=30

# Скорость печати (символов в секунду, 5-12 как у человека)
TYPING_SPEED_MIN=5
TYPING_SPEED_MAX=12